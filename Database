-- ====================================
-- Tenancy+ Rental Management Database 
-- ====================================

CREATE DATABASE IF NOT EXISTS `tenancy_db`;
USE `tenancy_db`;

--  Users Table
CREATE TABLE `users` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `name` varchar(200) NOT NULL,
  `username` varchar(100) NOT NULL,
  `password` text NOT NULL,
  `role` enum('Admin','Owner','Tenant','Staff') NOT NULL DEFAULT 'Tenant',
  `last_login` datetime DEFAULT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Owners Table
CREATE TABLE `owners` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `firstname` varchar(100) NOT NULL,
  `lastname` varchar(100) NOT NULL,
  `email` varchar(100) NOT NULL,
  `contact` varchar(50) NOT NULL,
  `address` text NOT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Categories Table
CREATE TABLE `categories` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `name` varchar(200) NOT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Houses Table
CREATE TABLE `houses` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `house_no` varchar(50) NOT NULL,
  `category_id` int(30) NOT NULL,
  `address` varchar(255) NOT NULL,
  `rooms` int(11) NOT NULL DEFAULT 1,
  `bathrooms` int(11) NOT NULL DEFAULT 1,
  `size_sqft` float DEFAULT NULL,
  `price` double NOT NULL,
  `availability_status` tinyint(1) NOT NULL DEFAULT 1 COMMENT '1=Available,0=Occupied',
  `owner_id` int(30) DEFAULT NULL,
  PRIMARY KEY (`id`),
  FOREIGN KEY (`category_id`) REFERENCES `categories`(`id`),
  FOREIGN KEY (`owner_id`) REFERENCES `owners`(`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Tenants Table
CREATE TABLE `tenants` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `firstname` varchar(100) NOT NULL,
  `middlename` varchar(100) DEFAULT NULL,
  `lastname` varchar(100) NOT NULL,
  `gender` enum('Male','Female','Other') DEFAULT NULL,
  `dob` date DEFAULT NULL,
  `email` varchar(100) NOT NULL,
  `contact` varchar(50) NOT NULL,
  `emergency_contact` varchar(100) DEFAULT NULL,
  `house_id` int(30) NOT NULL,
  `status` tinyint(1) NOT NULL DEFAULT 1 COMMENT '1=Active,0=Inactive',
  `date_in` date NOT NULL,
  `lease_end` date DEFAULT NULL,
  PRIMARY KEY (`id`),
  FOREIGN KEY (`house_id`) REFERENCES `houses`(`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Leases Table
CREATE TABLE `leases` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) NOT NULL,
  `house_id` int(30) NOT NULL,
  `start_date` date NOT NULL,
  `end_date` date NOT NULL,
  `monthly_rent` double NOT NULL,
  `security_deposit` double DEFAULT 0,
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE CASCADE,
  FOREIGN KEY (`house_id`) REFERENCES `houses`(`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Payments Table
CREATE TABLE `payments` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) NOT NULL,
  `amount` double NOT NULL,
  `payment_method` enum('Cash','Card','Online') NOT NULL DEFAULT 'Cash',
  `payment_status` enum('Pending','Completed','Failed') NOT NULL DEFAULT 'Completed',
  `invoice` varchar(50) NOT NULL,
  `date_created` datetime NOT NULL DEFAULT current_timestamp(),
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`)
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Queries Table
CREATE TABLE `queries` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) DEFAULT NULL,
  `subject` varchar(200) NOT NULL,
  `message` text NOT NULL,
  `status` enum('Pending','In Progress','Resolved','Closed') NOT NULL DEFAULT 'Pending',
  `date_created` datetime NOT NULL DEFAULT current_timestamp(),
  `date_updated` datetime DEFAULT NULL ON UPDATE current_timestamp(),
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Maintenance Requests Table
CREATE TABLE `maintenance_requests` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `house_id` int(30) NOT NULL,
  `tenant_id` int(30) DEFAULT NULL,
  `description` text NOT NULL,
  `status` enum('Pending','In Progress','Completed') NOT NULL DEFAULT 'Pending',
  `date_reported` datetime NOT NULL DEFAULT current_timestamp(),
  `date_resolved` datetime DEFAULT NULL,
  PRIMARY KEY (`id`),
  FOREIGN KEY (`house_id`) REFERENCES `houses`(`id`) ON DELETE CASCADE,
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Notifications Table
CREATE TABLE `notifications` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) DEFAULT NULL,
  `message` text NOT NULL,
  `is_read` tinyint(1) NOT NULL DEFAULT 0,
  `date_created` datetime NOT NULL DEFAULT current_timestamp(),
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE SET NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Feedback Table
CREATE TABLE `feedback` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) NOT NULL,
  `house_id` int(30) NOT NULL,
  `rating` int(1) NOT NULL CHECK (`rating` BETWEEN 1 AND 5),
  `comments` text,
  `date_submitted` datetime NOT NULL DEFAULT current_timestamp(),
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE CASCADE,
  FOREIGN KEY (`house_id`) REFERENCES `houses`(`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  Documents Table
CREATE TABLE `documents` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `tenant_id` int(30) NOT NULL,
  `doc_type` varchar(100) NOT NULL,
  `file_url` text NOT NULL,
  `uploaded_at` datetime NOT NULL DEFAULT current_timestamp(),
  PRIMARY KEY (`id`),
  FOREIGN KEY (`tenant_id`) REFERENCES `tenants`(`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

--  House Images Table
CREATE TABLE `house_images` (
  `id` int(30) NOT NULL AUTO_INCREMENT,
  `house_id` int(30) NOT NULL,
  `image_url` text NOT NULL,
  PRIMARY KEY (`id`),
  FOREIGN KEY (`house_id`) REFERENCES `houses`(`id`) ON DELETE CASCADE
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4;

COMMIT;
